    <button class="ctrl-btn" style="flex:1;height:28px;font-size:11px;" onclick="earnME(1.5)">🔗 Share</button>
    <button class="ctrl-btn" style="flex:1;height:28px;font-size:11px;" onclick="earnME(5)">📸 Save</button>
  </div>

  <!-- Photo ME indicator -->

  <div style="padding:0 12px 12px;display:flex;align-items:center;gap:8px;">
    <div style="flex:1;height:2px;background:#0a0a14;border-radius:1px;overflow:hidden;">
      <div id="photo-earn-bar" style="height:100%;background:linear-gradient(90deg,var(--amber),var(--green));width:0%;transition:width .5s ease;box-shadow:0 0 4px var(--amber);"></div>
    </div>
    <span id="photo-me" style="font-family:'Orbitron',monospace;font-size:9px;color:var(--amber);">0.0 ME</span>
  </div>
</div>

</div><!-- end grid -->

<!-- ═══ BOTTOM STATUS BAR ═══ -->

<div style="background:linear-gradient(90deg,#03030c,#070716,#03030c);border:1px solid #0e0e1a;border-radius:10px;padding:8px 16px;display:flex;align-items:center;gap:14px;overflow:hidden;position:relative;">
  <!-- LED row -->
  <div style="display:flex;gap:4px;flex-shrink:0;" id="status-leds"></div>
  <!-- Activity -->
  <div style="flex:1;overflow:hidden;">
    <div id="activity-text" style="font-size:10px;color:#555;letter-spacing:.06em;white-space:nowrap;transition:opacity .3s;">
      <span style="color:var(--red);margin-right:8px;font-family:'Orbitron',monospace;font-size:8px;animation:ledPulse 1.2s infinite;">◆ LIVE</span>levias bought 3 shares $DRAKE
    </div>
  </div>
  <!-- System states -->
  <div style="display:flex;gap:14px;flex-shrink:0;" id="sys-states"></div>
  <!-- Total ME -->
  <div style="background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.2);border-radius:6px;padding:5px 12px;flex-shrink:0;">
    <span id="me-total" style="font-family:'Orbitron',monospace;font-size:12px;font-weight:900;color:var(--accent2);">+0.0</span>
    <span style="font-size:8px;color:#444;margin-left:4px;letter-spacing:.08em;">ME</span>
  </div>
</div>

</div>
</div>

<script>
const TRACKS=[
  {title:"God's Plan",artist:"Drake",genre:"Hip-Hop",seed:"drk1",color:"#6366f1"},
  {title:"Crown Season",artist:"Nova Reigns",genre:"R&B",seed:"nv1",color:"#a78bfa"},
  {title:"Never Make A Promise",artist:"Dru Hill",genre:"R&B Soul",seed:"dh1",color:"#34d399"},
  {title:"Empire Rise",artist:"Nova Reigns",genre:"R&B",seed:"nv2",color:"#f472b6"},
  {title:"Hotline Bling",artist:"Drake",genre:"Hip-Hop",seed:"drk2",color:"#fbbf24"},
];
const VIDEOS=[
  {title:"Spring Lookbook 2025",creator:"Glamour Studio",handle:"glamourstudio",views:"3.1K",me:1700,seed:"gl1"},
  {title:"How I Edit for the Culture",creator:"PixelKingz",handle:"pixelkingz",views:"987",me:1100,seed:"pk_nyc"},
  {title:"My Investment Strategy",creator:"LEVIAS",handle:"levias",views:"445",me:461,seed:"lv1"},
  {title:"Tampa Community Talk",creator:"Marcus Williams",handle:"marcuswilliams",views:"2.1K",me:1300,seed:"mw1"},
];
const PHOTOS=[
  {title:"Behind the Lens",creator:"PixelKingz",seed:"pk_nyc"},
  {title:"Raw Bundle Arrivals",creator:"Glamour Studio",seed:"gl_bundle"},
  {title:"Studio Session",creator:"Drake",seed:"drk_studio"},
  {title:"Tampa Street Art",creator:"Marcus Williams",seed:"mw_tampa"},
  {title:"Crown Season Shoot",creator:"Nova Reigns",seed:"nv_shoot"},
  {title:"Empire Night",creator:"PixelKingz",seed:"pk_empire"},
];
const ACTIVITY=[
  "levias bought 3 shares $DRAKE","Alex R. tipped 20 ME to Nova","TampaRoots went LIVE",
  "PixelKingz posted new drop","850 fans streaming now","Hot Take Arena — vote now",
  "Squad Wars — top squad changes","Bella's merch drop LIVE","Drake stock up 12.3%",
];

let tIdx=0,vIdx=0,pIdx=0,playing=false,videoPlaying=false,meTotal=0,audioProgress=22,vol=78,videoProgress=0,slideTimer=100,photoMeTotal=0;
const likes={};
const BAR_COUNT=32;

function earnME(n){meTotal=Math.round((meTotal+n)*10)/10;document.getElementById("me-display").textContent=meTotal.toFixed(1);document.getElementById("me-total").textContent="+"+meTotal.toFixed(1);}

function toggleLike(key,reward){
  likes[key]=!likes[key];
  const btn=document.getElementById("like-"+key);
  if(btn){btn.style.color=likes[key]?"#f87171":"#666";btn.style.borderColor=likes[key]?"rgba(248,113,113,.4)":"#222236";}
  if(likes[key])earnME(reward);
}

// AUDIO
function updateTrackUI(){
  const t=TRACKS[tIdx];
  document.getElementById("track-title").textContent=t.title;
  document.getElementById("track-artist").textContent=t.artist;
  document.getElementById("track-genre").textContent=t.genre;
  document.getElementById("album-img").src=`https://picsum.photos/seed/${t.seed}/192/192`;
  document.getElementById("album-art").style.borderColor=t.color+"66";
  document.getElementById("album-art").style.boxShadow=`0 0 20px ${t.color}28,inset 0 0 20px rgba(0,0,0,.5)`;
  document.getElementById("outer-ring").style.borderColor=t.color+"33";
  document.getElementById("play-btn").style.background=`linear-gradient(135deg,${t.color},#8b5cf6)`;
  document.getElementById("play-btn").style.boxShadow=`0 0 18px ${t.color}55`;
  buildQueue();
}

function togglePlay(){
  playing=!playing;
  document.getElementById("play-btn").textContent=playing?"⏸":"▶";
  earnME(0.1);
}
function nextTrack(){tIdx=(tIdx+1)%TRACKS.length;audioProgress=0;updateTrackUI();}
function prevTrack(){tIdx=(tIdx-1+TRACKS.length)%TRACKS.length;audioProgress=0;updateTrackUI();}

function scrubAudio(e){const r=e.currentTarget.getBoundingClientRect();audioProgress=Math.round((e.clientX-r.left)/r.width*100);updateAudioProgress();}
function updateAudioProgress(){
  document.getElementById("audio-prog").style.width=audioProgress+"%";
  document.getElementById("audio-thumb").style.left=audioProgress+"%";
  const t=TRACKS[tIdx];document.getElementById("audio-prog").style.background=`linear-gradient(90deg,${t.color},#fff)`;
  document.getElementById("audio-prog").style.boxShadow=`0 0 8px ${t.color}`;
  document.getElementById("audio-thumb").style.boxShadow=`0 0 6px ${t.color}`;
  const secs=Math.round(audioProgress*2.22);document.getElementById("audio-cur").textContent=Math.floor(secs/60)+":"+String(secs%60).padStart(2,"0");
}

function scrubVol(e){const r=e.currentTarget.getBoundingClientRect();vol=Math.round((e.clientX-r.left)/r.width*100);document.getElementById("vol-fill").style.width=vol+"%";document.getElementById("vol-num").textContent=vol;}

function buildQueue(){
  const c=document.getElementById("queue");
  c.innerHTML=TRACKS.slice(0,4).map((t,i)=>`<div onclick="tIdx=${i};audioProgress=0;updateTrackUI();" style="display:flex;align-items:center;gap:6px;padding:5px 6px;border-radius:5px;cursor:pointer;background:${i===tIdx?"#0f0f22":"transparent"};transition:background .2s;">
    <div style="width:3px;height:22px;border-radius:2px;background:${i===tIdx?t.color:"#1a1a28"};flex-shrink:0;"></div>
    <img src="https://picsum.photos/seed/${t.seed}/48/48" style="width:22px;height:22px;border-radius:3px;object-fit:cover;flex-shrink:0;"/>
    <div style="flex:1;min-width:0;"><div style="font-size:9px;font-weight:600;color:${i===tIdx?"#fff":"#555"};white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${t.title}</div><div style="font-size:8px;color:#333;">${t.artist}</div></div>
    ${i===tIdx?`<span style="width:4px;height:4px;border-radius:50%;background:${t.color};animation:ledPulse 1s infinite;box-shadow:0 0 4px ${t.color};flex-shrink:0;"></span>`:""}
  </div>`).join("");
}

// SPECTRUM
function buildSpectrum(){
  const c=document.getElementById("spectrum");
  c.innerHTML=Array.from({length:BAR_COUNT}).map((_,i)=>`<div class="led-bar" id="bar${i}" style="flex:1;min-height:2px;border-radius:1px;background:#1a1a2e;"></div>`).join("");
}
function buildVU(){
  ["vu-l","vu-r"].forEach(id=>{
    document.getElementById(id).innerHTML=Array.from({length:14}).map((_,i)=>`<div id="${id}-${i}" style="flex:1;height:100%;border-radius:1px;background:#0e0e1a;"></div>`).join("");
  });
}
function updateSpectrum(){
  const intensity=playing?0.65+Math.random()*.35:0.1+Math.random()*.08;
  const base=Array.from({length:BAR_COUNT}).map((_,i)=>(Math.sin(i*.55+Date.now()*.003)*.5+.5)*intensity);
  base.forEach((h,i)=>{
    const el=document.getElementById("bar"+i);
    if(!el)return;
    const col=h>.82?"#f87171":h>.62?"#fbbf24":"#6366f1";
    el.style.height=Math.max(h*100,2)+"%";
    el.style.background=playing?col:"#1a1a2e";
    el.style.boxShadow=playing&&h>.55?`0 0 4px ${col}`:"none";
  });
  ["vu-l","vu-r"].forEach((id,ci)=>{
    const v=playing?0.42+Math.random()*.52:0.05+Math.random()*.07;
    for(let i=0;i<14;i++){
      const el=document.getElementById(`${id}-${i}`);if(!el)continue;
      const on=i/14<v;
      const col=i>11?"#f87171":i>8?"#fbbf24":"#34d399";
      el.style.background=on?col:"#0e0e1a";
      el.style.boxShadow=on?`0 0 3px ${col}`:"none";
    }
  });
}

// VIDEO
function nextVideo(){vIdx=(vIdx+1)%VIDEOS.length;videoProgress=0;updateVideoUI();}
function updateVideoUI(){
  const v=VIDEOS[vIdx];
  document.getElementById("video-img").src=`https://picsum.photos/seed/${v.seed}/900/506`;
  document.getElementById("vid-title").textContent=v.title;
  document.getElementById("vid-info").textContent=`@${v.handle} · ${v.views} views`;
  document.getElementById("vid-me").textContent=v.me.toLocaleString()+" ME";
  buildVidThumbs();
  earnME(0.25);
}
function toggleVideoPlay(){
  videoPlaying=!videoPlaying;
  document.getElementById("play-overlay").style.display=videoPlaying?"none":"flex";
  if(videoPlaying)earnME(0.25);
}
function scrubVideo(e){const r=e.currentTarget.getBoundingClientRect();videoProgress=Math.round((e.clientX-r.left)/r.width*100);updateVideoProgress();}
function updateVideoProgress(){
  document.getElementById("vid-prog").style.width=videoProgress+"%";
  document.getElementById("vid-thumb").style.left=videoProgress+"%";
  const secs=Math.round(videoProgress*3.14);document.getElementById("vid-cur").textContent=Math.floor(secs/60)+":"+String(secs%60).padStart(2,"0");
}
function buildVidThumbs(){
  const c=document.getElementById("vid-thumbs");
  c.innerHTML=VIDEOS.map((v,i)=>`<div onclick="vIdx=${i};videoProgress=0;updateVideoUI();" style="width:32px;height:22px;border-radius:4px;overflow:hidden;border:1px solid ${i===vIdx?"#6366f1":"#1e1e2e"};cursor:pointer;opacity:${i===vIdx?1:.45};transition:all .2s;">
    <img src="https://picsum.photos/seed/${v.seed}/64/44" style="width:100%;height:100%;object-fit:cover;"/></div>`).join("");
}

// PHOTO
let photoTransitioning=false;
function nextPhoto(){if(photoTransitioning)return;doPhotoTransition((pIdx+1)%PHOTOS.length);earnME(0.5);}
function prevPhoto(){if(photoTransitioning)return;doPhotoTransition((pIdx-1+PHOTOS.length)%PHOTOS.length);}
function doPhotoTransition(newIdx){
  photoTransitioning=true;
  const img=document.getElementById("photo-img");
  img.classList.remove("visible");img.classList.add("transitioning");
  setTimeout(()=>{
    pIdx=newIdx;const p=PHOTOS[pIdx];
    img.src=`https://picsum.photos/seed/${p.seed}/640/400`;
    document.getElementById("photo-title").textContent=p.title;
    document.getElementById("photo-creator").textContent=p.creator;
    document.getElementById("photo-counter").textContent=(pIdx+1)+"/"+PHOTOS.length;
    img.classList.remove("transitioning");img.classList.add("visible");
    slideTimer=100;buildPhotoGrid();photoTransitioning=false;
    photoMeTotal=Math.round((photoMeTotal+0.5)*10)/10;
    document.getElementById("photo-me").textContent=photoMeTotal.toFixed(1)+" ME";
    document.getElementById("photo-earn-bar").style.width=Math.min(photoMeTotal*4,100)+"%";
  },280);
}
function buildPhotoGrid(){
  const c=document.getElementById("photo-grid");
  c.innerHTML=PHOTOS.map((p,i)=>`<div onclick="if(${i}!==${pIdx})doPhotoTransition(${i});" style="aspect-ratio:16/9;border-radius:4px;overflow:hidden;border:1px solid ${i===pIdx?"#fbbf24":"#1a1a28"};cursor:pointer;opacity:${i===pIdx?1:.45};transition:all .2s;position:relative;">
    <img src="https://picsum.photos/seed/${p.seed}/120/68" style="width:100%;height:100%;object-fit:cover;"/>
    ${i===pIdx?`<div style="position:absolute;inset:0;border:1.5px solid #fbbf24;border-radius:4px;box-shadow:0 0 6px rgba(251,191,36,.4);pointer-events:none;"></div>`:""}
  </div>`).join("");
}

// STATUS BAR
function buildStatusBar(){
  document.getElementById("status-leds").innerHTML=["#34d399","#6366f1","#fbbf24","#f87171","#a78bfa"].map((c,i)=>`<div style="width:5px;height:5px;border-radius:50%;background:${c};box-shadow:0 0 5px ${c};animation:ledPulse ${1+i*.2}s infinite;"></div>`).join("");
  updateSysStates();
}
function updateSysStates(){
  const el=document.getElementById("sys-states");if(!el)return;
  const states=[{l:"AUDIO",v:playing?"PLAYING":"IDLE",c:playing?"#6366f1":"#2a2a3a"},{l:"VIDEO",v:videoPlaying?"PLAYING":"IDLE",c:videoPlaying?"#a78bfa":"#2a2a3a"},{l:"GALLERY",v:"ACTIVE",c:"#fbbf24"}];
  el.innerHTML=states.map(s=>`<div style="text-align:center;"><div style="font-family:'Orbitron',monospace;font-size:9px;font-weight:700;color:${s.c};${s.c!=="#2a2a3a"?"animation:ledPulse 1.5s infinite;":""}">${s.v}</div><div style="font-size:7px;color:#222;letter-spacing:.1em;margin-top:1px;">${s.l}</div></div>`).join("");
}

let actIdx=0;
function tickActivity(){
  const el=document.getElementById("activity-text");if(!el)return;
  el.style.opacity=0;
  setTimeout(()=>{
    actIdx=(actIdx+1)%ACTIVITY.length;
    el.innerHTML=`<span style="color:var(--red);margin-right:8px;font-family:'Orbitron',monospace;font-size:8px;animation:ledPulse 1.2s infinite;">◆ LIVE</span>${ACTIVITY[actIdx]}`;
    el.style.opacity=1;el.style.transition="opacity .3s";
  },300);
}

// MAIN LOOP
let frame=0;
function loop(){
  frame++;
  updateSpectrum();
  if(playing){audioProgress=Math.min(audioProgress+.12,100);updateAudioProgress();if(frame%8===0)earnME(0.08);}
  if(videoPlaying){videoProgress=Math.min(videoProgress+.08,100);updateVideoProgress();if(frame%10===0)earnME(0.05);}
  if(frame%80===0){slideTimer=Math.max(0,slideTimer-4);document.getElementById("slide-timer").style.width=slideTimer+"%";if(slideTimer<=0)nextPhoto();}
  if(frame%40===0)updateSysStates();
  document.getElementById("viewer-count").textContent=(5200+Math.round(Math.sin(frame*.01)*180)).toLocaleString().replace(",",".")+"."+Math.floor(Math.random()*9)+"K".replace(/\d+\.\dK/,"")
  requestAnimationFrame(loop);
}

// INIT
buildSpectrum();buildVU();updateTrackUI();buildVidThumbs();buildPhotoGrid();buildStatusBar();
setInterval(tickActivity,3500);
loop();
</script>

</body>
</html>