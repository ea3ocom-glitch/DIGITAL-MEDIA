*{box-sizing:border-box;margin:0;padding:0}
:root{--accent:#6366f1;--accent2:#a78bfa;--amber:#fbbf24;--red:#f87171;--green:#34d399;--pink:#f472b6}
body{background:linear-gradient(160deg,#04040e 0%,#080818 50%,#04040e 100%);min-height:100vh;font-family:'Rajdhani',system-ui,sans-serif;color:#fff;overflow-x:hidden}
@keyframes ledPulse{0%,100%{opacity:1}50%{opacity:.55}}
@keyframes orbit{0%{transform:rotate(0deg) translateX(28px) rotate(0deg)}100%{transform:rotate(360deg) translateX(28px) rotate(-360deg)}}
@keyframes kenBurns{0%{transform:scale(1);transform-origin:30% 40%}100%{transform:scale(1.08);transform-origin:70% 60%}}
@keyframes fadeSlide{from{opacity:0;transform:scale(.97)}to{opacity:1;transform:scale(1)}}
@keyframes scanMove{0%{top:-4%}100%{top:104%}}
@keyframes chromeShine{0%{background-position:200% center}100%{background-position:-200% center}}
@keyframes tickerPulse{0%,100%{color:#555}50%{color:#888}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes meFlash{0%,100%{opacity:1}50%{opacity:.5;transform:scale(1.1)}}
.ctrl-btn{background:linear-gradient(180deg,#1a1a2a 0%,#0d0d1a 100%);border:1px solid #222236;border-radius:6px;color:#666;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;font-family:'Rajdhani',sans-serif}
.ctrl-btn:hover{background:linear-gradient(180deg,#222240,#131325);color:#fff;border-color:var(--accent);box-shadow:0 0 8px rgba(99,102,241,.3)}
.ctrl-btn:active{transform:scale(.94)}
.led-bar{transition:height .07s ease,background .07s ease,box-shadow .07s ease}
.panel{background:linear-gradient(160deg,#0d0d1e 0%,#080814 100%);border:1px solid #1a1a2e;border-radius:14px;overflow:hidden;position:relative;box-shadow:0 0 0 1px #06060e,inset 0 1px 0 rgba(255,255,255,.05)}
.panel-center{background:#000;border:1px solid #1a1a2e;border-radius:14px;overflow:hidden;position:relative;box-shadow:0 0 0 1px #06060e,0 0 40px rgba(99,102,241,.08),inset 0 1px 0 rgba(255,255,255,.05);display:flex;flex-direction:column}
.chrome-bar-top{height:3px;background:linear-gradient(90deg,transparent 0%,var(--accent) 30%,#fff 50%,var(--accent2) 70%,transparent 100%)}
.chrome-bar-amber{height:3px;background:linear-gradient(90deg,transparent 0%,var(--amber) 30%,#fff 50%,var(--red) 70%,transparent 100%)}
.chrome-bar-center{height:4px;background:linear-gradient(90deg,#0d0d1e 0%,var(--accent) 20%,#fff 50%,var(--accent2) 80%,#0d0d1e 100%)}
.glass-sheen{position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.04) 0%,transparent 40%,rgba(255,255,255,.02) 100%);pointer-events:none}
.crt-lines{position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.05) 2px,rgba(0,0,0,.05) 4px);pointer-events:none}
.photo-img{width:100%;height:100%;object-fit:cover;animation:kenBurns 8s ease-in-out infinite alternate}
.photo-img.transitioning{opacity:0;transition:opacity .3s ease}
.photo-img.visible{opacity:1;transition:opacity .3s ease}
::-webkit-scrollbar{width:3px;background:#04040e}
::-webkit-scrollbar-thumb{background:#1a1a2e;border-radius:2px}
</style>
</head>
